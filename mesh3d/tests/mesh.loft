// Tests for the mesh sub-module of mesh3d.
use mesh3d;

fn test_mesh_create() {
  mc_m = mesh::mesh("test");
  assert(mc_m.name == "test", "mesh name");
  assert(mc_m.vertices.len() == 0, "empty verts");
  assert(mc_m.triangles.len() == 0, "empty tris");
}

fn test_mesh_add_vertex() {
  mv_m = mesh::mesh("v");
  mv_v = mesh::vertex(math::vec3(1.0, 2.0, 3.0), math::vec3(0.0, 1.0, 0.0), math::vec2(0.5, 0.5));
  mv_i = mv_m.add_vertex(mv_v);
  assert(mv_i == 0, "first vertex index");
  assert(mv_m.vertices.len() == 1, "one vertex");
}

fn test_mesh_add_triangle() {
  mt_m = mesh::mesh("t");
  mt_n = math::vec3(0.0, 0.0, 1.0);
  mt_uv = math::vec2(0.0, 0.0);
  mt_m.add_vertex(mesh::vertex(math::vec3(0.0, 0.0, 0.0), mt_n, mt_uv));
  mt_m.add_vertex(mesh::vertex(math::vec3(1.0, 0.0, 0.0), mt_n, mt_uv));
  mt_m.add_vertex(mesh::vertex(math::vec3(0.0, 1.0, 0.0), mt_n, mt_uv));
  mt_m.add_triangle(0, 1, 2);
  assert(mt_m.triangles.len() == 1, "one triangle");
  assert(mt_m.triangles[0].a == 0, "tri a");
  assert(mt_m.triangles[0].b == 1, "tri b");
  assert(mt_m.triangles[0].c == 2, "tri c");
}

fn test_cube() {
  cb = mesh::cube();
  assert(cb.name == "cube", "cube name");
  assert(cb.vertices.len() == 24, "cube has 24 verts (4 per face)");
  assert(cb.triangles.len() == 12, "cube has 12 tris (2 per face * 6 faces)");
}

fn test_plane() {
  pl = mesh::plane("ground", 2.0, 3.0);
  assert(pl.name == "ground", "plane name");
  assert(pl.vertices.len() == 4, "plane has 4 verts");
  assert(pl.triangles.len() == 2, "plane has 2 tris");
  // Check normal is up (y = 1)
  pln = pl.vertices[0].normal;
  assert(pln.y == 1.0, "normal up");
}

fn test_sphere() {
  sp = mesh::sphere("ball", 1.0, 8, 6);
  assert(sp.name == "ball", "sphere name");
  // (slices+1)*(stacks+1) = 9*7 = 63 verts
  assert(sp.vertices.len() == 63, "sphere verts={sp.vertices.len()}");
  // slices*stacks*2 = 8*6*2 = 96 tris
  assert(sp.triangles.len() == 96, "sphere tris={sp.triangles.len()}");
}
